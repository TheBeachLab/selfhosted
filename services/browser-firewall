#!/bin/sh
set -eu

CHAIN=REMOTE-BROWSER
SOURCE=172.31.250.0/28

add_rules() {
    iptables -N "$CHAIN" 2>/dev/null || true
    iptables -F "$CHAIN"
    iptables -A "$CHAIN" -m conntrack --ctstate ESTABLISHED,RELATED -j RETURN

    for destination in \
        0.0.0.0/8 \
        10.0.0.0/8 \
        100.64.0.0/10 \
        127.0.0.0/8 \
        169.254.0.0/16 \
        172.16.0.0/12 \
        192.0.0.0/24 \
        192.0.2.0/24 \
        192.168.0.0/16 \
        198.18.0.0/15 \
        198.51.100.0/24 \
        203.0.113.0/24 \
        224.0.0.0/4 \
        240.0.0.0/4
    do
        iptables -A "$CHAIN" -d "$destination" -j REJECT
    done

    iptables -A "$CHAIN" -j RETURN
    iptables -C DOCKER-USER -s "$SOURCE" -j "$CHAIN" 2>/dev/null ||
        iptables -I DOCKER-USER 1 -s "$SOURCE" -j "$CHAIN"
}

remove_rules() {
    while iptables -C DOCKER-USER -s "$SOURCE" -j "$CHAIN" 2>/dev/null; do
        iptables -D DOCKER-USER -s "$SOURCE" -j "$CHAIN"
    done
    iptables -F "$CHAIN" 2>/dev/null || true
    iptables -X "$CHAIN" 2>/dev/null || true
}

case "${1:-}" in
    add) add_rules ;;
    remove) remove_rules ;;
    *) echo "usage: $0 add|remove" >&2; exit 2 ;;
esac
